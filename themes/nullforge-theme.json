{
  "$schema": "vscode://schemas/color-theme",
  "name": "Nullforge",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    // editor surfaces
    "editor.background":                          "#0a1420",
    "editor.foreground":                          "#f2ece6",
    "editor.lineHighlightBackground":             "#1a2a3a66",
    "editor.lineHighlightBorder":                 "#00000000",
    "editor.selectionBackground":                 "#c4622d40",
    "editor.selectionHighlightBackground":        "#c4622d22",
    "editor.inactiveSelectionBackground":         "#c4622d22",
    "editor.wordHighlightBackground":             "#3d5a7544",
    "editor.wordHighlightStrongBackground":       "#3d5a7566",
    "editor.findMatchBackground":                 "#c4622d55",
    "editor.findMatchHighlightBackground":        "#c4622d22",
    "editor.hoverHighlightBackground":            "#3d5a7544",
    "editorWhitespace.foreground":                "#3d5a7555",
    "editorIndentGuide.background1":              "#1a2a3a",
    "editorIndentGuide.activeBackground1":        "#3d5a75",
    "editorLineNumber.foreground":                "#3d5a75",
    "editorLineNumber.activeForeground":          "#c4622d",
    "editorRuler.foreground":                     "#1a2a3a",
    "editorCursor.foreground":                    "#c4622d",
    "editorCursor.background":                    "#0a1420",
    "editorBracketMatch.background":              "#c4622d22",
    "editorBracketMatch.border":                  "#c4622d88",
    "editorBracketHighlight.foreground1":         "#c4622d",
    "editorBracketHighlight.foreground2":         "#e8a882",
    "editorBracketHighlight.foreground3":         "#7a9bb8",
    "editorBracketHighlight.foreground4":         "#8fb27e",
    "editorBracketHighlight.foreground5":         "#dce6f0",
    "editorBracketHighlight.foreground6":         "#f7e8df",

    // gutter / overview ruler
    "editorGutter.background":                    "#0a1420",
    "editorGutter.modifiedBackground":            "#c4622d",
    "editorGutter.addedBackground":               "#8fb27e",
    "editorGutter.deletedBackground":             "#d97264",
    "editorOverviewRuler.border":                 "#0a1420",
    "editorOverviewRuler.modifiedForeground":     "#c4622dcc",
    "editorOverviewRuler.addedForeground":        "#8fb27ecc",
    "editorOverviewRuler.deletedForeground":      "#d97264cc",
    "editorOverviewRuler.errorForeground":        "#d97264",
    "editorOverviewRuler.warningForeground":      "#c4622d",
    "editorOverviewRuler.infoForeground":         "#7a9bb8",

    // diagnostics
    "editorError.foreground":                     "#d97264",
    "editorWarning.foreground":                   "#c4622d",
    "editorInfo.foreground":                      "#7a9bb8",

    // activity bar (left rail)
    "activityBar.background":                     "#06101a",
    "activityBar.foreground":                     "#f2ece6",
    "activityBar.inactiveForeground":             "#3d5a75",
    "activityBar.activeBackground":               "#0a1420",
    "activityBar.activeBorder":                   "#c4622d",
    "activityBar.border":                         "#1a2a3a",
    "activityBarBadge.background":                "#c4622d",
    "activityBarBadge.foreground":                "#f2ece6",

    // sidebar (file explorer)
    "sideBar.background":                         "#0a1420",
    "sideBar.foreground":                         "#7a9bb8",
    "sideBar.border":                             "#1a2a3a",
    "sideBarTitle.foreground":                    "#f2ece6",
    "sideBarSectionHeader.background":            "#1a2a3a",
    "sideBarSectionHeader.foreground":            "#f2ece6",
    "sideBarSectionHeader.border":                "#06101a",
    "list.activeSelectionBackground":             "#c4622d",
    "list.activeSelectionForeground":             "#f2ece6",
    "list.inactiveSelectionBackground":           "#1a2a3a",
    "list.inactiveSelectionForeground":           "#f2ece6",
    "list.hoverBackground":                       "#1a2a3a66",
    "list.hoverForeground":                       "#f2ece6",
    "list.focusBackground":                       "#1a2a3a",
    "list.focusForeground":                       "#f2ece6",
    "list.highlightForeground":                   "#c4622d",
    "list.dropBackground":                        "#c4622d22",

    // tree icons / decorations
    "tree.indentGuidesStroke":                    "#1a2a3a",
    "gitDecoration.modifiedResourceForeground":   "#c4622d",
    "gitDecoration.addedResourceForeground":      "#8fb27e",
    "gitDecoration.deletedResourceForeground":    "#d97264",
    "gitDecoration.untrackedResourceForeground":  "#8fb27e",
    "gitDecoration.ignoredResourceForeground":    "#3d5a75",
    "gitDecoration.conflictingResourceForeground":"#d97264",

    // title bar / window chrome
    "titleBar.activeBackground":                  "#06101a",
    "titleBar.activeForeground":                  "#f2ece6",
    "titleBar.inactiveBackground":                "#06101a",
    "titleBar.inactiveForeground":                "#7a9bb8",
    "titleBar.border":                            "#1a2a3a",
    "menubar.selectionBackground":                "#1a2a3a",
    "menubar.selectionForeground":                "#f2ece6",

    // tabs
    "editorGroupHeader.tabsBackground":           "#06101a",
    "editorGroupHeader.tabsBorder":               "#1a2a3a",
    "editorGroupHeader.border":                   "#1a2a3a",
    "editorGroup.border":                         "#1a2a3a",
    "tab.activeBackground":                       "#0a1420",
    "tab.activeForeground":                       "#f2ece6",
    "tab.activeBorderTop":                        "#c4622d",
    "tab.activeBorder":                           "#0a1420",
    "tab.inactiveBackground":                     "#06101a",
    "tab.inactiveForeground":                     "#7a9bb8",
    "tab.hoverBackground":                        "#1a2a3a",
    "tab.hoverForeground":                        "#f2ece6",
    "tab.border":                                 "#1a2a3a",
    "tab.unfocusedActiveBorderTop":               "#3d5a75",

    // breadcrumbs
    "breadcrumb.background":                      "#0a1420",
    "breadcrumb.foreground":                      "#7a9bb8",
    "breadcrumb.focusForeground":                 "#f2ece6",
    "breadcrumb.activeSelectionForeground":       "#c4622d",
    "breadcrumbPicker.background":                "#0a1420",

    // status bar
    "statusBar.background":                       "#c4622d",
    "statusBar.foreground":                       "#f2ece6",
    "statusBar.border":                           "#8f4420",
    "statusBar.noFolderBackground":               "#1a2a3a",
    "statusBar.noFolderForeground":               "#f2ece6",
    "statusBar.debuggingBackground":              "#8f4420",
    "statusBar.debuggingForeground":              "#f2ece6",
    "statusBarItem.hoverBackground":              "#8f422088",
    "statusBarItem.remoteBackground":             "#1a2a3a",
    "statusBarItem.remoteForeground":             "#f2ece6",
    "statusBarItem.errorBackground":              "#a13c2a",
    "statusBarItem.errorForeground":              "#f2ece6",
    "statusBarItem.warningBackground":            "#8f4420",
    "statusBarItem.warningForeground":            "#f2ece6",

    // panel (terminal/output/problems)
    "panel.background":                           "#06101a",
    "panel.border":                               "#1a2a3a",
    "panelTitle.activeForeground":                "#c4622d",
    "panelTitle.activeBorder":                    "#c4622d",
    "panelTitle.inactiveForeground":              "#7a9bb8",
    "panelSectionHeader.background":              "#1a2a3a",

    // terminal — ANSI mapped to brand palette
    "terminal.background":                        "#06101a",
    "terminal.foreground":                        "#f2ece6",
    "terminal.ansiBlack":                         "#0a1420",
    "terminal.ansiRed":                           "#d97264",
    "terminal.ansiGreen":                         "#8fb27e",
    "terminal.ansiYellow":                        "#c4622d",
    "terminal.ansiBlue":                          "#7a9bb8",
    "terminal.ansiMagenta":                       "#e8a882",
    "terminal.ansiCyan":                          "#dce6f0",
    "terminal.ansiWhite":                         "#f2ece6",
    "terminal.ansiBrightBlack":                   "#3d5a75",
    "terminal.ansiBrightRed":                     "#d97264",
    "terminal.ansiBrightGreen":                   "#8fb27e",
    "terminal.ansiBrightYellow":                  "#e8a882",
    "terminal.ansiBrightBlue":                    "#7a9bb8",
    "terminal.ansiBrightMagenta":                 "#e8a882",
    "terminal.ansiBrightCyan":                    "#dce6f0",
    "terminal.ansiBrightWhite":                   "#f2ece6",
    "terminalCursor.background":                  "#0a1420",
    "terminalCursor.foreground":                  "#c4622d",

    // inputs / dropdowns / buttons
    "input.background":                           "#1a2a3a",
    "input.foreground":                           "#f2ece6",
    "input.border":                               "#3d5a75",
    "input.placeholderForeground":                "#7a9bb8",
    "inputOption.activeBackground":               "#c4622d44",
    "inputOption.activeBorder":                   "#c4622d",
    "inputOption.activeForeground":               "#f2ece6",
    "inputValidation.errorBackground":            "#a13c2a",
    "inputValidation.errorBorder":                "#d97264",
    "inputValidation.warningBackground":          "#8f4420",
    "inputValidation.warningBorder":              "#c4622d",
    "inputValidation.infoBackground":             "#1a2a3a",
    "inputValidation.infoBorder":                 "#7a9bb8",
    "dropdown.background":                        "#1a2a3a",
    "dropdown.foreground":                        "#f2ece6",
    "dropdown.border":                            "#3d5a75",
    "button.background":                          "#c4622d",
    "button.foreground":                          "#f2ece6",
    "button.hoverBackground":                     "#8f4420",
    "button.secondaryBackground":                 "#1a2a3a",
    "button.secondaryForeground":                 "#f2ece6",
    "button.secondaryHoverBackground":            "#3d5a75",
    "checkbox.background":                        "#1a2a3a",
    "checkbox.foreground":                        "#c4622d",
    "checkbox.border":                            "#3d5a75",

    // quickpick / command palette
    "quickInput.background":                      "#0a1420",
    "quickInput.foreground":                      "#f2ece6",
    "quickInputTitle.background":                 "#1a2a3a",
    "pickerGroup.foreground":                     "#c4622d",
    "pickerGroup.border":                         "#1a2a3a",

    // scrollbar
    "scrollbar.shadow":                           "#00000000",
    "scrollbarSlider.background":                 "#3d5a7555",
    "scrollbarSlider.hoverBackground":            "#3d5a7588",
    "scrollbarSlider.activeBackground":           "#c4622d88",

    // minimap
    "minimap.background":                         "#0a1420",
    "minimap.selectionHighlight":                 "#c4622da2",
    "minimap.findMatchHighlight":                 "#c4622da2",
    "minimap.errorHighlight":                     "#d97264",
    "minimap.warningHighlight":                   "#c4622d",
    "minimapSlider.background":                   "#3d5a7544",
    "minimapSlider.hoverBackground":              "#3d5a7566",
    "minimapSlider.activeBackground":             "#c4622d66",

    // notifications / badges
    "notificationCenter.border":                  "#1a2a3a",
    "notificationCenterHeader.background":        "#1a2a3a",
    "notificationCenterHeader.foreground":        "#f2ece6",
    "notifications.background":                   "#0a1420",
    "notifications.foreground":                   "#f2ece6",
    "notifications.border":                       "#1a2a3a",
    "notificationsErrorIcon.foreground":          "#d97264",
    "notificationsWarningIcon.foreground":        "#c4622d",
    "notificationsInfoIcon.foreground":           "#7a9bb8",
    "badge.background":                           "#c4622d",
    "badge.foreground":                           "#f2ece6",
    "progressBar.background":                     "#c4622d",

    // peek / diff / merge
    "peekView.border":                            "#c4622d",
    "peekViewEditor.background":                  "#1a2a3a",
    "peekViewEditor.matchHighlightBackground":    "#c4622d44",
    "peekViewResult.background":                  "#0a1420",
    "peekViewResult.selectionBackground":         "#c4622d44",
    "peekViewResult.selectionForeground":         "#f2ece6",
    "peekViewTitle.background":                   "#1a2a3a",
    "peekViewTitleLabel.foreground":              "#f2ece6",
    "peekViewTitleDescription.foreground":        "#7a9bb8",
    "diffEditor.insertedTextBackground":          "#8fb27e22",
    "diffEditor.removedTextBackground":           "#d9726422",
    "diffEditorGutter.insertedLineBackground":    "#8fb27e22",
    "diffEditorGutter.removedLineBackground":     "#d9726422",
    "merge.currentHeaderBackground":              "#c4622d66",
    "merge.currentContentBackground":             "#c4622d22",
    "merge.incomingHeaderBackground":             "#3d5a7588",
    "merge.incomingContentBackground":            "#3d5a7544",

    // editor widgets (suggest, hover, parameter hints, find, etc)
    "editorWidget.background":              "#0f1e2e",
    "editorWidget.foreground":              "#f2ece6",
    "editorWidget.border":                  "#1a2a3a",
    "editorWidget.resizeBorder":            "#c4622d",

    "editorSuggestWidget.background":       "#0f1e2e",
    "editorSuggestWidget.foreground":       "#f2ece6",
    "editorSuggestWidget.border":           "#1a2a3a",
    "editorSuggestWidget.selectedBackground":"#1a2a3a",
    "editorSuggestWidget.selectedForeground":"#f2ece6",
    "editorSuggestWidget.highlightForeground":"#c4622d",
    "editorSuggestWidget.focusHighlightForeground":"#e8a882",

    "editorHoverWidget.background":         "#0f1e2e",
    "editorHoverWidget.foreground":         "#f2ece6",
    "editorHoverWidget.border":             "#1a2a3a",
    "editorHoverWidget.statusBarBackground":"#06101a",

    "editorGhostText.foreground":           "#3d5a75",

    "editorMarkerNavigation.background":    "#0f1e2e",
    "editorMarkerNavigationError.background":   "#a13c2a",
    "editorMarkerNavigationWarning.background": "#8f4420",
    "editorMarkerNavigationInfo.background":    "#1a2a3a",

    // misc focus + borders
    "focusBorder":                                "#c4622d",
    "foreground":                                 "#f2ece6",
    "descriptionForeground":                      "#7a9bb8",
    "errorForeground":                            "#d97264",
    "icon.foreground":                            "#7a9bb8",
    "widget.shadow":                              "#00000088",
    "selection.background":                       "#c4622d40",
    "textLink.foreground":                        "#c4622d",
    "textLink.activeForeground":                  "#e8a882",
    "textBlockQuote.background":                  "#1a2a3a",
    "textBlockQuote.border":                      "#c4622d",
    "textCodeBlock.background":                   "#06101a",
    "textPreformat.foreground":                   "#e8a882",
    "textSeparator.foreground":                   "#1a2a3a"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7a9bb8", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#e8a882" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Numbers / constants",
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": { "foreground": "#e8a882" }
    },
    {
      "name": "Booleans / null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation"],
      "settings": { "foreground": "#dce6f0" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#f7e8df" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#dce6f0", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#f2ece6" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#7a9bb8" }
    },
    {
      "name": "Types / classes",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "storage.type.class"],
      "settings": { "foreground": "#e8a882" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.other.inherited-class", "entity.name.type.interface"],
      "settings": { "foreground": "#e8a882", "fontStyle": "italic" }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#e8a882", "fontStyle": "italic" }
    },
    {
      "name": "Markup headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#c4622d", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#f2ece6", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#f2ece6", "fontStyle": "italic" }
    },
    {
      "name": "Markup link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#c4622d", "fontStyle": "underline" }
    },
    {
      "name": "Markup code",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": { "foreground": "#e8a882" }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#7a9bb8", "fontStyle": "italic" }
    },
    {
      "name": "Markup added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#8fb27e" }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#d97264" }
    },
    {
      "name": "Markup changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#c4622d" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#d97264", "fontStyle": "underline" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#e8a882" }
    },
    {
      "name": "Embedded punctuation (JSX braces)",
      "scope": ["punctuation.section.embedded", "meta.brace"],
      "settings": { "foreground": "#7a9bb8" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#e8a882", "fontStyle": "italic" }
    },
    {
      "name": "TOML / INI keys",
      "scope": ["entity.name.tag.toml", "keyword.key.toml"],
      "settings": { "foreground": "#c4622d" }
    }
  ]
}
